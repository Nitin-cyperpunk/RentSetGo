{
  "name": "rentsetgo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "sync:qr": "node scripts/sync-qr.mjs",
    "sync:brand": "node scripts/sync-brand.mjs",
    "og:generate": "node scripts/generate-og-image.mjs",
    "dev": "pnpm sync:qr && pnpm sync:brand && pnpm og:generate && next dev",
    "build": "pnpm sync:qr && pnpm sync:brand && pnpm og:generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:types": "pnpm dlx supabase@latest gen types typescript --linked > types/database.types.ts",
    "db:pull": "pnpm dlx supabase@latest db pull",
    "db:push": "pnpm dlx supabase@latest db push",
    "db:link": "pnpm dlx supabase@latest link"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "@tailwindcss/postcss": "^4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.2",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver",
      "msw"
    ]
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "typescript": "^5"
  }
}
