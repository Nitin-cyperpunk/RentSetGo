# Ensure Tailwind v4 resolves when Next/webpack/postcss resolve `tailwindcss` from CSS (pnpm strict layout).
public-hoist-pattern[]=*tailwindcss*
public-hoist-pattern[]=*@tailwindcss*

# pnpm 11+: allow install to succeed; native builds are whitelisted in package.json "pnpm.onlyBuiltDependencies"
strict-dep-builds=false
